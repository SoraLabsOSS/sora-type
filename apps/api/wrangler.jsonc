{
  "compatibility_date": "2025-10-08",
  "main": "src/index.ts",
  "name": "sora-type",
  "upload_source_maps": true,
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["0 3 * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sora-type",
      "database_id": "55eee246-2743-4ff2-a9c6-a795af17e42c",
      "migrations_dir": "drizzle"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "sora-type"
    }
  ]
}
