{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "!.next/dev/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test:e2e": {
      "dependsOn": ["build"]
    },
    "build:languages": {
      "outputs": ["src/data/languages.json"]
    },
    "check:font": {
      "cache": false
    },
    "//#check": {
      "cache": false
    },
    "//#fix": {
      "cache": false
    }
  }
}
